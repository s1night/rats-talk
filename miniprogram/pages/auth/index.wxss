/* 容器 */
.container {
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 标题 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.tip {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 80rpx;
}

/* 头像区域（核心美化） */
.avatar-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

/* 把默认 button 样式隐藏，只保留功能 */
.avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
}

/* 头像圆形样式 */
.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f5f5f5;
  border: 4rpx solid #f2f2f2;
}

.avatar-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 20rpx;
}

/* 昵称输入框 */
.input-box {
  width: 100%;
  margin-bottom: 80rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 30rpx;
  background: #f7f8fa;
  border-radius: 44rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

/* 确认按钮 */
.confirm-btn {
  width: 100%;
  height: 88rpx;
  background: #000; /* 鼠鼠黄色主题 */
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}