/* pages/index/index.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-top: 128rpx;
  padding-bottom: 100rpx;
}

.search-box {
  padding: 24rpx;
  background-color: #ffffff;
  box-sizing: border-box;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.search-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 40rpx;
  padding: 0 60rpx 0 32rpx;
  font-size: 32rpx;
  background-color: #f9f9f9;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.search-input:focus {
  border-color: #000000;
  background-color: #ffffff;
  box-shadow: 0 0 0 2rpx rgba(0, 0, 0, 0.1);
}

.clear-btn {
  position: absolute;
  right: 44rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #999999;
  border-radius: 50%;
  z-index: 1;
}

.clear-btn text {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1;
}

.post-list {
  padding-bottom: 24rpx;
}

.post-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
}

.post-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.header-info {
  flex: 1;
}

.club-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 8rpx;
  display: block;
}

.user-info {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666666;
}

.nickname {
  margin-right: 8rpx;
}

.dot {
  margin: 0 8rpx;
  color: #999999;
}

.user-tag {
  background-color: #f0f0f0;
  color: #666666;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.post-content {
  margin-bottom: 16rpx;
}

.content {
  font-size: 32rpx;
  line-height: 1.5;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.post-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #999999;
}

.view-count {
  display: flex;
  align-items: center;
}

.create-time {
  font-size: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 32rpx;
}

.empty-text {
  margin-bottom: 32rpx;
  display: block;
}

.publish-btn {
  background-color: #000000;
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 1;
  text-align: center;
  width: 240rpx;
  margin: 0 auto;
  border: none;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.publish-btn:active {
  background-color: #333333;
  transform: scale(0.98);
}

.loading {
  text-align: center;
  padding: 48rpx 0;
  color: #666666;
  font-size: 28rpx;
}

.loading-more {
  text-align: center;
  padding: 32rpx 0;
  color: #999999;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  color: #999999;
  font-size: 26rpx;
  margin-bottom: 100rpx;
}
