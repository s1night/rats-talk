/* pages/publish/index.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
}

.back-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 32rpx;
  color: #000000;
  line-height: 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
  flex: 1;
  text-align: center;
}

.right-placeholder {
  width: 40rpx;
  height: 40rpx;
}

/* 发布按钮 */
.publish-btn {
  min-width: 80rpx;
  padding: 8rpx 16rpx;
  text-align: right;
}

.publish-btn-text {
  font-size: 32rpx;
  color: #000000;
  font-weight: 600;
}

/* 法律责任提示 */
.legal-tip {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #999999;
  background-color: #f9f9f9;
  margin-bottom: 16rpx;
}

/* 表单部分 */
.form-section {
  background-color: #ffffff;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.form-section-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 80rpx;
}

.field-label-inline {
  font-size: 32rpx;
  font-weight: 500;
  color: #000000;
  margin-right: 24rpx;
  flex-shrink: 0;
  line-height: 1;
}

.field-label {
  font-size: 32rpx;
  font-weight: 500;
  color: #000000;
  margin-bottom: 16rpx;
}

.field-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.char-limit {
  font-size: 24rpx;
  color: #999999;
}

/* 身份选择 */
.identity-select {
  display: flex;
  gap: 24rpx;
  align-items: center;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.radio-label {
  font-size: 32rpx;
  color: #000000;
  line-height: 1;
}

/* 输入框 */
.input-container {
  position: relative;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 40rpx 0 20rpx;
  font-size: 32rpx;
  color: #333333;
  background-color: #ffffff;
  box-sizing: border-box;
}

.dropdown-arrow {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #999999;
}

/* 文本域 */
.textarea {
  width: 100%;
  height: 380rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 32rpx;
  color: #333333;
  background-color: #ffffff;
  resize: none;
  box-sizing: border-box;
  line-height: 48rpx;
}

.content-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999999;
  line-height: 36rpx;
}

/* 图片上传 */
.upload-area {
  margin-top: 16rpx;
}

.upload-list {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.upload-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.upload-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.6);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.upload-btn {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx dashed #e0e0e0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f9f9f9;
}

.upload-btn text {
  font-size: 48rpx;
  color: #999999;
  line-height: 48rpx;
}

.upload-tip {
  font-size: 24rpx;
  color: #999999;
  line-height: 36rpx;
}

/* 加载提示 */
.loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  backdrop-filter: blur(10rpx);
}

/* 底部发布按钮 */
.bottom-publish {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
}

.bottom-publish .publish-btn {
  width: 100%;
  height: 88rpx;
  background-color: #000000;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.bottom-publish .publish-btn[loading] {
  background-color: #666666;
}
