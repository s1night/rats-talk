<view class="container">
  <!-- 游客模式 -->
  <view class="user-info" wx:if="{{!isLoggedIn}}">
    <image class="avatar" src="../../images/avatar.jpeg" mode="aspectFill" />
    <text class="nickname">游客</text>
  </view>

  <!-- 登录模式 -->
  <view class="user-info" wx:else>
    <image class="avatar" src="{{userInfo.avatarUrl || '../../images/avatar.jpeg'}}" mode="aspectFill" />
    <text class="nickname">{{userInfo.nickName || '用户'}}</text>
  </view>

  <!-- 游客模式引导 -->
  <view class="section" wx:if="{{!isLoggedIn}}">
    <view class="guide-state">
      <text class="guide-text">登录后即可查看您发布的所有帖子，并与大家互动交流</text>
      <button class="login-btn" bindtap="goToAuth">微信授权登录</button>
    </view>
  </view>

  <!-- 登录后显示入口 -->
  <view class="section" wx:else>
    <view class="menu-card">
      <view class="menu-item" bindtap="goToMyPosts">
        <text class="menu-title">我的帖子</text>
        <image class="menu-arrow" src="/images/icons/arrow_right.png" mode="aspectFit" />
      </view>
      <view class="menu-item menu-divider" bindtap="goToHelpCenter">
        <text class="menu-title">帮助中心</text>
        <image class="menu-arrow" src="/images/icons/arrow_right.png" mode="aspectFit" />
      </view>
      <view class="menu-item menu-divider" bindtap="goToUserAgreement">
        <text class="menu-title">用户协议</text>
        <image class="menu-arrow" src="/images/icons/arrow_right.png" mode="aspectFit" />
      </view>
      <view class="menu-item menu-divider" bindtap="goToPrivacyPolicy">
        <text class="menu-title">隐私政策</text>
        <image class="menu-arrow" src="/images/icons/arrow_right.png" mode="aspectFit" />
      </view>
      <view class="menu-item menu-divider" bindtap="goToAboutUs">
        <text class="menu-title">关于我们</text>
        <image class="menu-arrow" src="/images/icons/arrow_right.png" mode="aspectFit" />
      </view>
      <view class="menu-item menu-divider" bindtap="logout">
        <text class="menu-title menu-danger">退出登录</text>
        <image class="menu-arrow" src="/images/icons/arrow_right.png" mode="aspectFit" />
      </view>
    </view>
  </view>
</view>
