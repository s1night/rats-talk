/* pages/profile/index.wxss */
.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  object-fit: cover;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #000000;
}

.section {
  padding-bottom: 100rpx;
}

.guide-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  margin: 48rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.guide-text {
  font-size: 32rpx;
  color: #333333;
  line-height: 48rpx;
  margin-bottom: 48rpx;
}

.login-btn {
  width: 240rpx;
  height: 88rpx;
  background-color: #000000;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: none;
}

.login-btn::after {
  border: none;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #000000;
  padding: 24rpx;
  letter-spacing: 2rpx;
}

.post-list {
  margin-bottom: 24rpx;
}

.post-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  padding: 28rpx;
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.post-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.club-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
}

.status {
  font-size: 28rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.status::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.1;
  z-index: -1;
}

.status.pending {
  color: #666666;
  background-color: #f5f5f5;
}

.status.pending::before {
  background-color: #666666;
}

.status.approved {
  color: #00c851;
  background-color: #e8f5e8;
}

.status.approved::before {
  background-color: #00c851;
}

.status.rejected {
  color: #ff3b30;
  background-color: #fff0f0;
}

.status.rejected::before {
  background-color: #ff3b30;
}

.post-content {
  margin-bottom: 20rpx;
}

.content {
  font-size: 32rpx;
  color: #000000;
  line-height: 48rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 16rpx;
}

.post-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  object-fit: cover;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.create-time {
  font-size: 28rpx;
  color: #999999;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.action-btn.edit {
  color: #000000;
  background-color: #f5f5f5;
  border: 1rpx solid #e0e0e0;
}

.action-btn.edit:active {
  background-color: #e0e0e0;
}

.action-btn.delete {
  color: #ff3b30;
  background-color: #fff0f0;
  border: 1rpx solid #ffcccc;
}

.action-btn.delete:active {
  background-color: #ffe0e0;
}

.empty-state {
  text-align: center;
  padding: 160rpx 0;
  color: #999999;
  font-size: 32rpx;
  line-height: 48rpx;
}

.publish-btn {
  margin-top: 48rpx;
  width: 240rpx;
  height: 88rpx;
  background-color: #000000;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.publish-btn:active {
  background-color: #333333;
  transform: scale(0.98);
}

.loading {
  text-align: center;
  padding: 48rpx 0;
  color: #666666;
  font-size: 28rpx;
}

.loading-more {
  text-align: center;
  padding: 32rpx 0;
  color: #999999;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  color: #999999;
  font-size: 26rpx;
}

.login-btn {
  margin-top: 48rpx;
  width: 240rpx;
  height: 88rpx;
  background-color: #000000;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.login-btn:active {
  background-color: #333333;
  transform: scale(0.98);
}