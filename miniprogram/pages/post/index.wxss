/* pages/post/index.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.post-detail {
  background-color: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  padding: 28rpx;
  transition: all 0.3s ease;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  position: relative;
  flex-wrap: nowrap;
}

.more-btn {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-btn image {
  width: 32rpx;
  height: 32rpx;
}

.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.user-info {
  flex: 1;
}

.header-info {
  flex: 1;
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
}

.nickname {
  font-size: 26rpx;
  font-weight: 400;
  color: #999999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex-shrink: 1;
  margin-right: 8rpx;
}

.identity-tag {
  background-color: #f0f0f0;
  color: #666666;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.identity-boss {
  background-color: #e3f2fd;
  color: #1976d2;
}

.identity-employee {
  background-color: #fff3e0;
  color: #ff9800;
}

.create-time {
  font-size: 26rpx;
  color: #999999;
}

.identity {
  font-size: 24rpx;
  color: #666666;
  background-color: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  display: inline-block;
}

.status {
  font-size: 28rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.status::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.1;
  z-index: -1;
}

.status.pending {
  color: #666666;
  background-color: #f5f5f5;
}

.status.pending::before {
  background-color: #666666;
}

.status.rejected {
  color: #ff3b30;
  background-color: #fff0f0;
}

.status.rejected::before {
  background-color: #ff3b30;
}

.club-info {
  margin-bottom: 24rpx;
}

.club-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #000000;
  letter-spacing: 2rpx;
}

.post-content {
  margin-bottom: 24rpx;
}

.content {
  font-size: 32rpx;
  color: #000000;
  line-height: 48rpx;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
}

.image-swiper {
  margin-top: 24rpx;
  position: relative;
}

.swiper {
  width: 100%;
  height: 600rpx;
  background-color: #f5f5f5;
}

swiper-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: aspectFit;
}

.swiper-indicator {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 4rpx 16rpx;
  border-radius: 5rpx;
  display: flex;
  align-items: center;
}

.indicator-text {
  color: #ffffff;
  font-size: 24rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.post-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  object-fit: cover;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  color: #999999;
  font-size: 26rpx;
}

.view-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  vertical-align: middle;
}

.view-wrapper {
  display: flex;
  align-items: center;
}

.view-count {
  display: flex;
  align-items: center;
}

/* 审核不通过原因 */
.reject-reason {
  margin-top: 24rpx;
  padding: 20rpx;
  background-color: #fff0f0;
  border-radius: 12rpx;
}

.reject-label {
  font-size: 26rpx;
  color: #ff3b30;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.reject-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

/* 更多操作弹窗 */
.more-menu {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.menu-content {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  padding: 32rpx;
  animation: slideUp 0.3s ease;
}

.menu-item {
  display: block;
  text-align: center;
  font-size: 32rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  color: #000000;
  transition: all 0.3s ease;
}

.menu-item:last-child {
  border-bottom: none;
  margin-top: 16rpx;
  color: #999999;
}

.menu-item.delete {
  color: #ff3b30;
}

.menu-item:active {
  background-color: #f5f5f5;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}