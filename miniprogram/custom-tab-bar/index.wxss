.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #e5e5e5;
  justify-content: space-around;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 24rpx;
}

.publish-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  margin-top: 15rpx;
}

.publish-icon {
  width: 40rpx;
  height: 40rpx;
  z-index: 1;
}

.publish-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 70rpx;
  height: 70rpx;
  background-color: #000000;
  border-radius: 10rpx;
  z-index: 0;
}
